      "Bash(tasklist:*)",
      "Bash(taskkill:*)",
      "Bash(pkill:*)",
      "Bash(kill:*)",
      "Bash(mkdir:*)",
      "Bash(git:*)",
      "Bash(export:*)",
      "Bash(bash scripts/start-server-logged.sh:*)",
      "Bash(cd:*)",
      "Read",
      "Edit",
      "Write",
      "Skill(update-config:*)",
      "Skill(qae-monitor:*)"
